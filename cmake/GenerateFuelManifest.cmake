if(NOT DEFINED FISSION_FUEL_DIR OR NOT DEFINED MANIFEST_OUT OR NOT DEFINED UNIFIED_OUT)
  message(FATAL_ERROR "FISSION_FUEL_DIR, MANIFEST_OUT and UNIFIED_OUT are required")
endif()

file(GLOB FUEL_JSON_FILES RELATIVE "${FISSION_FUEL_DIR}" "${FISSION_FUEL_DIR}/*.json")
list(SORT FUEL_JSON_FILES)

set(FILES_JSON "[\n")
set(UNIFIED_JSON "[\n")
set(FIRST_ENTRY TRUE)
set(FIRST_UNIFIED_ENTRY TRUE)
foreach(FILE_NAME IN LISTS FUEL_JSON_FILES)
  if(FILE_NAME STREQUAL "files.json" OR FILE_NAME STREQUAL "fission_fuel.json")
    continue()
  endif()

  if(NOT FIRST_ENTRY)
    string(APPEND FILES_JSON ",\n")
  endif()
  string(APPEND FILES_JSON "  \"${FILE_NAME}\"")
  set(FIRST_ENTRY FALSE)

  file(READ "${FISSION_FUEL_DIR}/${FILE_NAME}" FILE_CONTENT_RAW)
  string(REGEX REPLACE "^[ \t\r\n]*\\[" "" FILE_CONTENT "${FILE_CONTENT_RAW}")
  string(REGEX REPLACE "\\][ \t\r\n]*$" "" FILE_CONTENT "${FILE_CONTENT}")
  string(STRIP "${FILE_CONTENT}" FILE_CONTENT)
  if(FILE_CONTENT STREQUAL "")
    continue()
  endif()
  if(NOT FIRST_UNIFIED_ENTRY)
    string(APPEND UNIFIED_JSON ",\n")
  endif()
  string(APPEND UNIFIED_JSON "${FILE_CONTENT}")
  set(FIRST_UNIFIED_ENTRY FALSE)
endforeach()
string(APPEND FILES_JSON "\n]\n")
string(APPEND UNIFIED_JSON "\n]\n")

file(WRITE "${MANIFEST_OUT}" "${FILES_JSON}")
file(WRITE "${UNIFIED_OUT}" "${UNIFIED_JSON}")
